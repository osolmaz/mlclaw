{
  "agents": {
    "defaults": {
      "workspace": "${OPENCLAW_WORKSPACE_DIR}",
      "model": {
        "primary": "${OPENCLAW_MODEL}"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 7861,
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "x-forwarded-user",
        "requiredHeaders": ["x-forwarded-proto", "x-forwarded-host"],
        "allowLoopback": true
      }
    },
    "trustedProxies": ["127.0.0.1", "::1"],
    "controlUi": {
      "dangerouslyDisableDeviceAuth": true,
      "allowedOrigins": ["${MLCLAW_PUBLIC_URL}"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": [],
      "timeoutSeconds": 45,
      "pollingStallThresholdMs": 60000,
      "commands": {
        "native": false
      },
      "network": {
        "autoSelectFamily": false,
        "dnsResultOrder": "ipv4first"
      }
    }
  },
  "messages": {
    "queue": {
      "byChannel": {
        "telegram": "collect"
      },
      "debounceMsByChannel": {
        "telegram": 1500
      },
      "cap": 20,
      "drop": "summarize"
    }
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "idle",
      "idleMinutes": 2147483647
    },
    "maintenance": {
      "resetArchiveRetention": false
    }
  },
  "cron": {
    "enabled": true
  }
}
