---
import { LICENSE_URL, REPOSITORY_URL, SITE_NAME } from "../site";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/mlclaw.svg`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a class="brand" href={`${base}/`}>
          <img src={`${base}/mlclaw.svg`} alt="" width="28" height="25" />
          <span>{SITE_NAME}</span>
        </a>
        <div class="links">
          <a href={`${base}/getting-started/`}>Getting started</a>
          <a href={`${base}/how-it-works/`}>How it works</a>
          <a href={`${base}/costs/`}>Costs</a>
          <a href={REPOSITORY_URL}>GitHub</a>
        </div>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>
        <a href={REPOSITORY_URL}>GitHub</a> ·
        <a href={LICENSE_URL}>MIT License</a> · Built on OpenClaw and Hugging Face.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fffdf5;
    --text: #32343d;
    --muted: #6b6e7b;
    --yellow: #ffd21e;
    --orange: #ff9d00;
    --red: #ef1f1f;
    --border: #ece7d8;
    --code-bg: #32343d;
    --code-text: #ffd21e;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      "Segoe UI",
      Roboto,
      sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .site-header {
    border-bottom: 1px solid var(--border);
  }

  .site-header nav {
    max-width: 60rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-header .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .site-header .links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .site-header .links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .site-header .links a:hover {
    color: var(--text);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 1.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .site-footer a {
    color: inherit;
  }
</style>
