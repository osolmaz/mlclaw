{
  "rules": [
    {
      "id": "mlclaw-read-repositories",
      "effect": "allow",
      "clients": ["default"],
      "operations": ["repo.list", "repo.metadata.read", "repo.contents.read", "git.fetch"],
      "targets": [
        {"kind": "repo", "type": "*", "owner": "*", "name": "*"}
      ]
    },
    {
      "id": "mlclaw-append-repositories",
      "effect": "allow",
      "clients": ["default"],
      "operations": ["git.push.append"],
      "targets": [
        {"kind": "repo", "type": "*", "owner": "*", "name": "*"}
      ]
    },
    {
      "id": "mlclaw-list-router-models",
      "effect": "allow",
      "clients": ["default"],
      "operations": ["inference.models.list"],
      "targets": [
        {"kind": "inference", "owner": "router", "name": "models"}
      ]
    },
    {
      "id": "mlclaw-use-router-models",
      "effect": "allow",
      "clients": ["default"],
      "operations": ["inference.chat.complete"],
      "targets": [
        {"kind": "inference", "owner": "*", "name": "*"}
      ]
    },
    {
      "id": "mlclaw-request-repository-creation",
      "effect": "request",
      "clients": ["default"],
      "operations": ["repo.create"],
      "targets": [
        {"kind": "repo", "type": "model", "owner": "*", "name": "*"},
        {"kind": "repo", "type": "dataset", "owner": "*", "name": "*"}
      ],
      "attrs": {
        "private": "*"
      },
      "grant_policy": {
        "mode": "execution",
        "default_minutes": 5,
        "max_minutes": 5,
        "request_ttl_minutes": 15,
        "default_max_uses": 1,
        "max_uses": 1
      }
    },
    {
      "id": "mlclaw-request-space-creation",
      "effect": "request",
      "clients": ["default"],
      "operations": ["repo.create"],
      "targets": [
        {"kind": "repo", "type": "space", "owner": "*", "name": "*"}
      ],
      "attrs": {
        "private": "*",
        "sdk": "*"
      },
      "grant_policy": {
        "mode": "execution",
        "default_minutes": 5,
        "max_minutes": 5,
        "request_ttl_minutes": 15,
        "default_max_uses": 1,
        "max_uses": 1
      }
    },
    {
      "id": "mlclaw-request-protected-repository-writes",
      "effect": "request",
      "clients": ["default"],
      "operations": ["git.push.force", "git.ref.delete", "git.tag.update"],
      "targets": [
        {"kind": "repo", "type": "*", "owner": "*", "name": "*"}
      ],
      "grant_policy": {
        "default_minutes": 5,
        "max_minutes": 60,
        "request_ttl_minutes": 15,
        "default_max_uses": 1,
        "max_uses": 3
      }
    }
  ]
}
